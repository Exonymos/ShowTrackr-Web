# apps/desktop/data/.env.example
# Copy this file to .env and fill in your values.
# The setup script (scripts/setup.bat or scripts/setup.sh) does this automatically.

# Flask Secret Key — generate with: python -c "import secrets; print(secrets.token_hex(24))"
SECRET_KEY='CHANGE_ME'

# Flask app module path (do not change)
FLASK_APP=apps/desktop/src/core

# Set to False for production
FLASK_DEBUG=True

# Informational — the app resolves the DB path automatically from DATA_DIR
DATABASE_URL=sqlite:///./apps/desktop/data/database.db

# Feedback form URLs (optional — leave blank to disable)
GOOGLE_APPS_SCRIPT_FEEDBACK_URL=''
GOOGLE_SHEET_PUBLIC_URL=''
